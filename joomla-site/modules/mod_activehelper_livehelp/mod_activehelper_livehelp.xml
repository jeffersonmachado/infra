<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="1.6.0" client="site" method="upgrade">
<name>ActiveHelper LiveHelp Module</name>
<author>ActiveHelper</author>
<creationDate>September 2013</creationDate>
<copyright>Copyright 2011 - 2012 by ActiveHelper Inc. All rights reserved</copyright>
<license>GNU/GPLv3 http://www.gnu.org/copyleft/gpl.html</license>
<authorEmail>support@activehelper.com</authorEmail>
<authorUrl>www.activehelper.com</authorUrl>
<version>1.5</version>
<description>A module for livehelp system tracking</description>
<files>
<filename module="mod_activehelper_livehelp">mod_activehelper_livehelp.php</filename>
<filename>mod_activehelper_livehelp.xml</filename>
</files>
<config>
<fields name="params">
<fieldset name="basic">
<field name="languages" type="list" default="English" label="language" description="Tracking module language">
<option value="en">English</option>
<option value="sp">Spanish</option>
<option value="de">German</option>
<option value="pt">Portuguese</option>
<option value="it">Italian</option>
<option value="fr">French</option>
<option value="cz">Czech</option>
<option value="se">Swedish</option>
<option value="no">Norwegian</option>
<option value="tr">Turkey</option>
<option value="gr">Greek</option>
<option value="he">Hebrew</option>
<option value="fa">Farsi</option>
<option value="sr">Serbian</option>
<option value="ru">Russian</option>
<option value="hu">Hungarian</option>
<option value="zh">Traditional Chinese</option>
<option value="cn">Simplified Chinese</option>
<option value="ar">Arab</option>
<option value="nl">Dutch</option>
<option value="fi">Finnish</option>
<option value="dk">Danish</option>
<option value="pl">Polish</option>
<option value="bg">Bulgarian</option>
<option value="sk">Slovak</option>
<option value="cr">Croatian</option>
<option value="id">Indonesian</option>
<option value="lt">Lithuanian</option>
<option value="ro">Romanian</option>
<option value="sl">Slovenian</option>
<option value="et">Estonian</option>
<option value="lv">Latvian</option>
</field>
<field name="tracking" type="radio" default="1" label="Tracking" description="Use Trackin">
<option value="1">Enable</option>
<option value="0">Disable</option>
</field>
<field name="status_indicator" type="radio" default="1" label="Status Indicator" description="Use Status Indicator">
<option value="1">Enable</option>
<option value="0">Disable</option>
</field>
<field name="agent_id" type="text" default="0" label="Agent ID" description="Use only for agent status indicator, the general status indicator is 0" />
</fieldset>
</fields>
</config>
</extension>