<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="3.1" client="site" method="upgrade">
	<name>MOD_ACCORDIONSLIDE</name>
	<author>Joomla! Project</author>
	<creationDate>July 2006</creationDate>
	<copyright>Copyright (C) 2005 - 2015 Open Source Matters. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>admin@joomla.org</authorEmail>
	<authorUrl>www.joomla.org</authorUrl>
	<version>3.0.0</version>
	<description>MOD_ACCORDIONSLIDE_XML_DESCRIPTION</description>
	<files>
		<filename module="mod_accordionslide">mod_accordionslide.php</filename>
		<folder>tmpl</folder>
		<folder>assets</folder>
		<folder>language</folder>
		<filename>helper.php</filename>
		<filename>mod_accordionslide.xml</filename>
	</files>
	<languages>
		<language tag="en-GB">language/en-GB/en-GB.mod_accordionslide.ini</language>
		<language tag="en-GB">language/en-GB/en-GB.mod_accordionslide.sys.ini</language>
	</languages>
	<help key="JHELP_EXTENSIONS_MODULE_MANAGER_ARTICLES_NEWSFLASH" />
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="catid"
					type="category"
					extension="com_content"
					multiple="true"
					default=""
					size="10"
					label="JCATEGORY"
					description="MOD_ACCORDIONSLIDE_FIELD_CATEGORY_DESC"
				>
					<option value="">JOPTION_ALL_CATEGORIES</option>
				</field>

                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
                    
                <field
                    name="item_title_show"
                    class="btn-group btn-group-yesno"
                    type="radio"
                    default="1"
                    label="MOD_ACCORDIONSLIDE_FIELD_TITLE_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_TITLE_DESC"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>    
                <field
                    name="introtext_show"
                    class="btn-group btn-group-yesno"
                    type="radio"
                    default="1"
                    label="MOD_ACCORDIONSLIDE_FIELD_INTROTEXT_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_INTROTEXT_DESC"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>                                     
				<field
					name="autoplay"
					type="radio"
					class="btn-group btn-group-yesno"
					default="true"
					label="MOD_ACCORDIONSLIDE_FIELD_AUTO_LABEL"
					description="MOD_ACCORDIONSLIDE_FIELD_AUTO_DESC"
				>
					<option value="true">JYES</option>
					<option value="false">JNO</option>
				</field>
                <field
                    name="count_panel"
                    type="text"
                    default="7"
                    label="MOD_ACCORDIONSLIDE_FIELD_COUNT_PANEL_ITEMS_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_COUNT_PANEL_ITEMS_DESC" />
				<field
					name="count"
					type="text"
					default="14"
					label="MOD_ACCORDIONSLIDE_FIELD_COUNT_ITEMS_LABEL"
					description="MOD_ACCORDIONSLIDE_FIELD_COUNT_ITEMS_DESC" />
                <field
                    name="count_text"
                    type="text"
                    default="100"
                    label="MOD_ACCORDIONSLIDE_FIELD_COUNT_TEXT_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_COUNT_TEXT_DESC" /> 
                <field
                    name="width_slider"
                    type="text"
                    default="960"
                    label="MOD_ACCORDIONSLIDE_FIELD_SLIDER_WIDTH_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_SLIDER_WIDTH_DESC" /> 
                <field
                    name="height_slider"
                    type="text"
                    default="400"
                    label="MOD_ACCORDIONSLIDE_FIELD_SLIDER_HEIGHT_LABEL"
                    description="MOD_ACCORDIONSLIDE_FIELD_SLIDER_HEIGHT_DESC" />                                                             

				<field
					name="ordering"
					type="list"
					default="a.publish_up"
					label="MOD_ACCORDIONSLIDE_FIELD_ORDERING_LABEL"
					description="MOD_ACCORDIONSLIDE_FIELD_ORDERING_DESC"
				>
					<option value="a.publish_up">MOD_ACCORDIONSLIDE_FIELD_ORDERING_PUBLISHED_DATE</option>
					<option value="a.created">MOD_ACCORDIONSLIDE_FIELD_ORDERING_CREATED_DATE</option>
					<option value="a.ordering">MOD_ACCORDIONSLIDE_FIELD_ORDERING_ORDERING</option>
					<option value="a.hits">JGLOBAL_HITS</option>
					<option value="rand()">MOD_ACCORDIONSLIDE_FIELD_ORDERING_RANDOM</option>
				</field>

				<field
					name="direction"
					type="list"
					default="1"
					label="JGLOBAL_ORDER_DIRECTION_LABEL"
					description="JGLOBAL_ORDER_DIRECTION_DESC"
				>
					<option value="0">JGLOBAL_ORDER_ASCENDING</option>
					<option value="1">JGLOBAL_ORDER_DESCENDING</option>
				</field>
			</fieldset>

			<fieldset name="advanced">

				<field
					name="moduleclass_sfx"
					type="textarea" rows="3"
					label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
					description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC" />

				<field
					name="cache"
					type="list"
					default="1"
					label="COM_MODULES_FIELD_CACHING_LABEL"
					description="COM_MODULES_FIELD_CACHING_DESC"
				>
					<option value="1">JGLOBAL_USE_GLOBAL</option>
					<option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
				</field>

				<field
					name="cache_time"
					type="text"
					default="900"
					label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
					description="COM_MODULES_FIELD_CACHE_TIME_DESC" />

				<field
					name="cachemode"
					type="hidden"
					default="itemid"
				>
					<option value="itemid"></option>
				</field>
			</fieldset>
		</fields>
	</config>
	<updateservers>
		<server type="extension" priority="1" name="Plugin Before after slide update">http://www.omegatheme.com/jedupdates/mod_accordionslide/extension.xml</server>
	</updateservers>
</extension>
